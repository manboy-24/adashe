# ── Base de données MySQL ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=tontine_db
DB_USERNAME=root
DB_PASSWORD=ton_mot_de_passe_mysql

# ── JWT ────────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 64
JWT_SECRET=CHANGE_ME

# ── Email (Gmail App Password) ─────────────────────────────────────────────────
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ── Firebase (facultatif en dev) ───────────────────────────────────────────────
FIREBASE_CREDENTIALS=classpath:firebase-service-account.json

# ── CinetPay (MTN + Orange Cameroun) ──────────────────────────────────────────
# Inscription gratuite: https://cinetpay.com
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_NOTIFY_URL=https://api.tontineplus.cm/api/paiements/webhook/cinetpay
CINETPAY_RETURN_URL=https://app.tontineplus.cm/paiement/retour

# ── MTN MoMo (optionnel si CinetPay suffit) ───────────────────────────────────
MTN_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_SUBSCRIPTION_KEY=
MTN_API_USER=
MTN_API_KEY=
MTN_ENV=sandbox
MTN_CALLBACK_URL=

# ── Orange Money (optionnel si CinetPay suffit) ────────────────────────────────
ORANGE_CLIENT_ID=
ORANGE_CLIENT_SECRET=
ORANGE_MERCHANT_KEY=

# ── Africa's Talking (SMS) ─────────────────────────────────────────────────────
# Inscription: https://account.africastalking.com
# Sandbox gratuit pour les tests (pas besoin de carte SIM)
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=TontinePlus
